{
  "resources": {
    "FileSystem": {
      "hasResourcePolicy": true,
      "grants": {
        "read": {
          "actions": [
            "s3files:ClientMount"
          ],
          "docSummary": "Grant read access to this file system (mount)"
        },
        "readWrite": {
          "actions": [
            "s3files:ClientMount",
            "s3files:ClientWrite"
          ],
          "docSummary": "Grant read and write access to this file system"
        },
        "rootAccess": {
          "actions": [
            "s3files:ClientMount",
            "s3files:ClientWrite",
            "s3files:ClientRootAccess"
          ],
          "docSummary": "Grant root-level access to this file system"
        }
      }
    }
  }
}
