{
  "name": "@aws-cdk/validation-engine",
  "version": "0.0.0",
  "private": false,
  "description": "CloudFormation template validation engine for AWS CDK",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "jsii": {
    "tsconfig": "tsconfig.json",
    "outdir": "dist",
    "targets": {},
    "metadata": {
      "jsii": {
        "rosetta": {
          "strict": false
        }
      }
    },
    "validateTsconfig": "minimal"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/aws-cdk.git",
    "directory": "packages/@aws-cdk/validation-engine"
  },
  "scripts": {
    "build": "cdk-build",
    "watch": "cdk-watch",
    "test": "cdk-test",
    "package": "cdk-package",
    "build+test": "yarn build && yarn test"
  },
  "keywords": [
    "aws",
    "cdk",
    "validation",
    "cloudformation"
  ],
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com",
    "organization": true
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@aws-cdk/cdk-build-tools": "0.0.0",
    "@aws-cdk/pkglint": "0.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "stability": "experimental",
  "maturity": "experimental",
  "publishConfig": {
    "tag": "latest"
  }
}
