       "Principal": {
        "Service": "bedrock-agentcore.amazonaws.com"
       }
      }
     ],
     "Version": "2012-10-17"
    }
   }
  },
  "MemoryWithStreamDeliveryServiceRoleDefaultPolicy0FFA2F76": {
