{
  "$": "A tsconfig for the library files, used in compilation of the library",
  "extends": "./tsconfig.options.json",
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "**/test/**/*.ts",
    "**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../tools/@aws-cdk/cdk-build-tools"
    },
    {
      "path": "../../tools/@aws-cdk/pkglint"
    },
    {
      "path": "../@aws-cdk/aws-custom-resource-sdk-adapter"
    },
    {
      "path": "../../tools/@aws-cdk/spec2cdk"
    }
  ]
}
