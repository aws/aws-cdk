{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node20",
    "lib": [
      "es2022",
      "dom"
    ],
    "strict": true,
    "alwaysStrict": true,
    "declaration": true,
    "sourceMap": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "composite": true,
    "isolatedModules": true,
    "incremental": true,
    "esModuleInterop": true,
    "types": [
      "jest",
      "node"
    ],
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "config.ts",
    "**/*.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "resources/**/*",
    "**/*.snapshot/**/*"
  ]
}
