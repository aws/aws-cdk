        "mixin": "aws-cdk-lib.MetadataContextMixin"
      }
    },
    {
      "type": "aws:cdk:metadata-context",
      "data": {
        "context": {
          "deps": [
            "NetworkStack"
          ]
        },
        "options": {
          "applyToAllResources": false
        }
      }
    }
  ],
  "/MetadataContextMixinTestStack/BootstrapVersion": [
    {
      "type": "aws:cdk:logicalId",
      "data": "BootstrapVersion"
    }
  ],
  "/MetadataContextMixinTestStack/CheckBootstrapVersion": [
    {
      "type": "aws:cdk:logicalId",
      "data": "CheckBootstrapVersion"
    }
  ]
