{
  "name": "@aws-cdk/check-peer-dependencies",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "check-peer-dependencies": "bin/check-peer-dependencies"
  },
  "scripts": {
    "build": "tsc --build && chmod +x bin/check-peer-dependencies",
    "build+test": "npm run build && npm run test",
    "lint": "eslint --ext .ts,.tsx --fix --no-error-on-unmatched-pattern bin lib test",
    "package": "mkdir -p dist/js && mv $(npm pack) dist/js/",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "watch": "tsc --build -w"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/semver": "^7.7.1",
    "@aws-cdk/cdk-build-tools": "0.0.0",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "semver": "^7.8.5"
  },
  "main": "lib/index.js",
  "license": "Apache-2.0"
}
