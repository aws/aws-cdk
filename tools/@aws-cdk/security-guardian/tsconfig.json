{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node20",
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "jest",
      "node"
    ],
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src"
  ]
}
